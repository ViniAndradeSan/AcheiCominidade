{
	"$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
	"extends": ["../../tooling/biome/base.json"],
	"files": {
		"ignoreUnknown": false,
		"includes": ["**/*.{ts,tsx,json,jsonc,css}"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useConst": "on",
				"useNamingConvention": "off"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			}
		}
	}
}