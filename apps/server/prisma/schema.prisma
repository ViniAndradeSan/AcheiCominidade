generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "bun"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

enum ItemStatus {
  disponivel
  devolvido
}

model ItemCategory {
  id         String      @id @default(uuid())
  name       String      @unique
  slug       String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  foundItems FoundItem[]

  @@map("item_categories")
}

model FoundItem {
  id                String         @id @default(uuid())
  title             String
  description       String?
  categoryId        String         @map("category_id")
  category          ItemCategory   @relation(fields: [categoryId], references: [id])
  status            ItemStatus     @default(disponivel)
  photoUrl          String         @map("photo_url")
  foundLocationText String         @map("found_location_text")
  foundLatitude     Float?         @map("found_latitude")
  foundLongitude    Float?         @map("found_longitude")
  foundAt           DateTime       @default(now()) @map("found_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  itemReturn        ItemReturn?

  @@map("found_items")
}

model ItemReturn {
  id          String    @id @default(uuid())
  itemId      String    @unique @map("item_id")
  item        FoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  returnedAt  DateTime  @default(now()) @map("returned_at")
  observation String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("item_returns")
}
