{
	"name": "server",
	"$schema": "https://json.schemastore.org/package.json",
	"type": "module",
	"module": "src/main.ts",
	"scripts": {
		"build": "NODE_ENV=production bun run scripts/build.ts",
		"start": "NODE_ENV=development tsc && bun .",
		"start:dev": "NODE_ENV=development tsc-watch --onSuccess \"bun .\"",
		"start:debug": "NODE_ENV=development tsc-watch --onSuccess \"bun . --inspect\"",
		"start:prod": "NODE_ENV=production bun dist/main.js",
		"check": "biome check --write .",
		"lint": "biome ci .",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:cov": "bun test --coverage",
		"test:debug": "bun --inspect-brk --runInBand",
		"test:e2e": "bun test ./test/app.e2e-spec.ts",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"postinstall": "prisma generate"
	},
	"dependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/core": "^10.0.0",
		"@nestjs/mapped-types": "*",
		"@nestjs/platform-express": "^10.0.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"pg": "^8.22.0",
		"reflect-metadata": "^0.2.0",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"@nestjs/testing": "^10.0.0",
		"@tooling/biome": "workspace:^",
		"@types/bun": "^1.1.13",
		"@types/express": "^5.0.0",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^6.0.0",
		"dotenv": "^17.4.2",
		"prettier": "^3.0.0",
		"prisma": "^7.8.0",
		"supertest": "^7.0.0",
		"tsc-watch": "^6.2.1",
		"typescript": "^5.1.3"
	},
	"trustedDependencies": [
		"@nestjs/core"
	]
}
