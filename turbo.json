{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**"]
		},
		"lint": {},
		"check": {
			"cache": false
		},
		"test": {},
		"start": {
			"cache": false,
			"persistent": true
		},
		"start:dev": {
			"cache": false,
			"persistent": true
		}
	}
}
